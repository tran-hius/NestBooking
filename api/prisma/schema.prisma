// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  AGENT
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
  BANNED
}

enum HotelStatus {
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

enum RoomStatus {
  AVAILABLE
  BOOKED
  OCCUPIED
  MAINTENANCE
}

enum BedType {
  SINGLE
  DOUBLE
  QUEEN
  KING
  TWIN
  BUNK
}

model User {
  id                String         @id @default(uuid()) @db.Uuid
  email             String         @unique @db.VarChar(255)
  passwordHash      String?         @map("password_hash") @db.VarChar(255)
  role              Role           @default(USER)
  status            UserStatus     @default(PENDING)
  loginAttempts     Int            @default(0) @map("login_attempts")
  lockUntil         DateTime?      @map("lock_until")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")
  profile           UserProfile?
  agentProfile      AgentProfile? 
  refreshTokens     RefreshToken[]

  @@map("users")
}

model UserProfile {
  userId                  String    @id @map("user_id") @db.Uuid
  fullName                String    @map("full_name") @db.VarChar(100)
  phoneNumber             String?   @unique @map("phone_number") @db.VarChar(15)
  avatarUrl               String?   @map("avatar_url") @db.Text
  address                 String?   @db.Text
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}


model AgentProfile {
  userId          String     @id @map("user_id") @db.Uuid
  businessName    String     @map("business_name") @db.VarChar(150)
  businessLicense String?    @map("business_license") @db.Text  
  taxCode         String?    @map("tax_code") @db.VarChar(50)
  idNumber        String?    @map("id_number")      
  idCardImageUrl  String?    @map("id_card_image_url")
  approvalStatus  UserStatus @default(PENDING) @map("approval_status") 
  approvedAt      DateTime?  @map("approved_at")
  rejectedReason  String?    @map("rejected_reason") @db.Text
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotels Hotel[]
  @@map("agent_profiles")
}

model RefreshToken {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String     @map("user_id") @db.Uuid
  tokenHash     String     @map("token_hash") @db.VarChar(255)
  deviceName    String?    @map("device_name") @db.VarChar(100)
  ipAddress     String?    @map("ip_address") @db.VarChar(45)
  userAgent     String?    @map("user_agent") @db.Text
  expiresAt     DateTime   @map("expires_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  lastUsedAt    DateTime?  @map("last_used_at")
  revokedAt     DateTime?  @map("revoked_at")
  revokeReason  String?    @map("revoke_reason") @db.VarChar(100)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Hotel {
  id            String      @id @default(uuid()) @db.Uuid
  ownerId       String      @db.Uuid
  name          String      @db.VarChar(255)
  slug          String      @unique @db.VarChar(255)
  description   String?     @db.Text
  address       String      @db.Text
  city          String      @db.VarChar(100)
  country       String      @default("Vietnam") @db.VarChar(100)
  latitude      Decimal?    @db.Decimal(10,8)
  longitude     Decimal?    @db.Decimal(11,8)
  phone         String?     @db.VarChar(20)
  email         String?     @db.VarChar(255)
  thumbnail     String?     @db.Text
  amenities     String[]    @default([])
  rating        Float       @default(0)
  checkInTime   String?     @db.VarChar(10)
  checkOutTime  String?     @db.VarChar(10)
  status        HotelStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  owner         AgentProfile @relation(fields: [ownerId], references: [userId], onDelete: Cascade)
  images        HotelImage[]
  rooms         Room[]
  roomTypes     RoomType[]
  @@map("hotels")
}

model HotelImage {
  id         String   @id @default(uuid()) @db.Uuid
  hotelId    String   @db.Uuid
  imageUrl   String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  @@map("hotel_images")
}

model RoomType {
  id            String    @id @default(uuid()) @db.Uuid
  hotelId       String    @db.Uuid
  name          String    @db.VarChar(150)
  description   String?   @db.Text
  price         Decimal   @db.Decimal(12,2)
  maxGuests     Int
  maxAdults     Int
  maxChildren   Int
  bedType       BedType
  bedCount      Int
  area          Float?
  thumbnail     String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  rooms Room[]
  images RoomTypeImage[]
  @@unique([hotelId,name])
  @@map("room_types")
}


model Room {
  id            String      @id @default(uuid()) @db.Uuid
  hotelId       String      @db.Uuid
  roomTypeId    String      @db.Uuid
  roomNumber    String      @db.VarChar(30)
  floor         Int?
  status        RoomStatus  @default(AVAILABLE)
  note          String?     @db.Text
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  @@unique([hotelId,roomNumber])
  @@map("rooms")
}


model RoomTypeImage {
  id          String    @id @default(uuid()) @db.Uuid
  roomTypeId  String    @db.Uuid
  imageUrl    String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  @@map("room_type_images")
}

