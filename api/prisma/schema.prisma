// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  AGENT
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
  BANNED
}

model User {
  id                String         @id @default(uuid()) @db.Uuid
  email             String         @unique @db.VarChar(255)
  passwordHash      String?         @map("password_hash") @db.VarChar(255)
  role              Role           @default(USER)
  status            UserStatus     @default(PENDING)
  loginAttempts     Int            @default(0) @map("login_attempts")
  lockUntil         DateTime?      @map("lock_until")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  profile           UserProfile?
  agentProfile      AgentProfile? 
  refreshTokens     RefreshToken[]

  @@map("users")
}

model UserProfile {
  userId                  String    @id @map("user_id") @db.Uuid
  fullName                String    @map("full_name") @db.VarChar(100)
  phoneNumber             String?   @unique @map("phone_number") @db.VarChar(15)
  avatarUrl               String?   @map("avatar_url") @db.Text
  address                 String?   @db.Text
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}


model AgentProfile {
  userId          String   @id @map("user_id") @db.Uuid
  businessName    String   @map("business_name") @db.VarChar(150)
  businessLicense String?  @map("business_license") @db.Text  // URL ảnh giấy phép
  taxCode         String?  @map("tax_code") @db.VarChar(50)
  approvalStatus  UserStatus @default(PENDING) @map("approval_status") // tái dùng enum có sẵn
  approvedAt      DateTime? @map("approved_at")
  rejectedReason  String @map("rejected_reason") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agent_profiles")
}

model RefreshToken {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String     @map("user_id") @db.Uuid
  tokenHash     String     @map("token_hash") @db.VarChar(255)
  deviceName    String?    @map("device_name") @db.VarChar(100)
  ipAddress     String?    @map("ip_address") @db.VarChar(45)
  userAgent     String?    @map("user_agent") @db.Text
  expiresAt     DateTime   @map("expires_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  lastUsedAt    DateTime?  @map("last_used_at")
  revokedAt     DateTime?  @map("revoked_at")
  revokeReason  String?    @map("revoke_reason") @db.VarChar(100)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}