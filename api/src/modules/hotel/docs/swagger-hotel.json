  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "CreateHotelDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Khách sạn Mường Thanh"
          },
          "description": {
            "type": "string",
            "example": "Khách sạn 5 sao..."
          },
          "address": {
            "type": "string",
            "example": "123 Đường Trần Phú"
          },
          "city": {
            "type": "string",
            "example": "Nha Trang"
          },
          "country": {
            "type": "string",
            "example": "Vietnam"
          },
          "latitude": {
            "type": "number",
            "example": 12.238791
          },
          "longitude": {
            "type": "number",
            "example": 109.196749
          },
          "phone": {
            "type": "string",
            "example": "0123456789"
          },
          "email": {
            "type": "string",
            "example": "contact@muongthanh.com"
          },
          "thumbnail": {
            "type": "string",
            "example": "https://example.com/image.jpg"
          },
          "amenities": {
            "type": "array",
            "example": [
              "WIFI",
              "SWIMMING_POOL",
              "SPA",
              "GYM",
              "BAR"
            ],
            "items": {
              "type": "string"
            }
          },
          "checkInTime": {
            "type": "string",
            "example": "14:00"
          },
          "checkOutTime": {
            "type": "string",
            "example": "12:00"
          }
        },
        "required": [
          "name",
          "address",
          "city"
        ]
      },
      "UpdateHotelDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Khách sạn Mường Thanh"
          },
          "description": {
            "type": "string",
            "example": "Khách sạn 5 sao..."
          },
          "address": {
            "type": "string",
            "example": "123 Đường Trần Phú"
          },
          "city": {
            "type": "string",
            "example": "Nha Trang"
          },
          "country": {
            "type": "string",
            "example": "Vietnam"
          },
          "amenities": {
            "type": "array",
            "example": [
              "WIFI",
              "SWIMMING_POOL"
            ],
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "example": "ACTIVE"
          }
        }
      },
      "CreateRoomTypeDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Phòng Standard"
          },
          "price": {
            "type": "number",
            "example": 500000
          },
          "maxGuests": {
            "type": "number",
            "example": 2
          },
          "maxAdults": {
            "type": "number",
            "example": 2
          },
          "maxChildren": {
            "type": "number",
            "example": 1
          },
          "bedType": {
            "type": "string",
            "example": "SINGLE"
          },
          "bedCount": {
            "type": "number",
            "example": 1
          },
          "area": {
            "type": "number",
            "example": 25
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "amenities": {
            "type": "array",
            "example": [
              "WIFI",
              "AC"
            ],
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name",
          "price",
          "maxGuests",
          "maxAdults",
          "maxChildren",
          "bedType",
          "bedCount"
        ]
      },
      "UpdateRoomTypeDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Phòng Standard"
          },
          "price": {
            "type": "number",
            "example": 500000
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "amenities": {
            "type": "array",
            "example": [
              "WIFI",
              "AC"
            ],
            "items": {
              "type": "string"
            }
          }
        }
      },
      "AddRoomTypeImagesDto": {
        "type": "object",
        "properties": {
          "imageUrls": {
            "type": "array",
            "example": [
              "https://example.com/img1.jpg",
              "https://example.com/img2.jpg"
            ],
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "imageUrls"
        ]
      },
      "CreateRoomDto": {
        "type": "object",
        "properties": {
          "roomTypeId": {
            "type": "string",
            "example": "uuid-1234"
          },
          "roomNumber": {
            "type": "string",
            "example": "101"
          },
          "floor": {
            "type": "number",
            "example": 1
          }
        },
        "required": [
          "roomTypeId",
          "roomNumber"
        ]
      },
      "UpdateRoomDto": {
        "type": "object",
        "properties": {
          "roomNumber": {
            "type": "string",
            "example": "101"
          },
          "floor": {
            "type": "number",
            "example": 1
          },
          "status": {
            "type": "string",
            "example": "AVAILABLE"
          }
        }
      }
    }
  }
}