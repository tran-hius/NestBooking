{
  "compilerOptions": {
    "baseUrl": "./src",
    "outDir": "dist",
    "paths": {
      "@/*": ["*"],
      "#generated/*": ["../generated/*"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "rootDir": "src"
  },
  "include": [
    "src/**/*"
  ]
}